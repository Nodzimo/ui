{
	"name": "@sefo/nodzimo-ui",
	"description": "Sefo Nodzimo UI",
	"keywords": [
		"Sefo",
		"Nodzimo",
		"UI",
		"NUI",
		"SNUI",
		"React",
		"TypeScript",
		"Tailwind",
		"Components",
		"ShadCN",
		"Storybook",
		"RTL"
	],
	"publishConfig": {
		"access": "public"
	},
	"version": "0.0.4",
	"author": {
		"name": "Sefo Nodzimo",
		"email": "Sefo@Nodzimo.com",
		"url": "https://Nodzimo.com"
	},
	"license": "MIT",
	"homepage": "https://github.com/Nodzimo/nodzimo-ui",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Nodzimo/nodzimo-ui.git"
	},
	"bugs": {
		"url": "https://github.com/Nodzimo/nodzimo-ui/issues",
		"email": "Sefo@Nodzimo.com"
	},
	"funding": [
		{
			"type": "Individual",
			"url": "https://Nodzimo.com/donate"
		},
		{
			"type": "Boosty",
			"url": "https://boosty.to/Nodzimo"
		}
	],
	"type": "module",
	"files": [
		"dist"
	],
	"imports": {
		"#lib": "./src/lib/index.ts",
		"#lib/*": "./src/lib/*/index.ts",
		"#core": "./src/core/index.ts",
		"#core/*": "./src/core/*/index.ts",
		"#client": "./src/client/index.ts",
		"#client/*": "./src/client/*/index.ts"
	},
	"exports": {
		".": {
			"import": "./dist/nodzimo-ui.js",
			"types": "./dist/nodzimo-ui.d.ts"
		},
		"./client": {
			"import": "./dist/client.js",
			"types": "./dist/client.d.ts"
		},
		"./styles.css": "./dist/styles.css"
	},
	"scripts": {
		"project:audit": "bun run build:ts && bun run check:lint && bun run check:deps && bun run deps:outdated",
		"project:verify": "bun run deps:install && bun run project:audit && bun run build:icons && bun run build:js && bun run build:css && bun run lib:pack",
		"dev": "vite",
		"preview": "vite preview",
		"build": "bun run build:ts && bun run build:js",
		"build:js": "vite build",
		"build:js-watch": "bun run build:js --watch",
		"build:ts": "tsc --build",
		"build:ts-watch": "bun run build:ts --watch",
		"build:css": "tailwindcss --input src/styles.css --output dist/styles.css --minify",
		"build:css-watch": "bun run build:css --watch",
		"build:icons": "svgr assets/icons && bun run check:fix-unsafe",
		"build:all": "bun run build:icons && bun run build && bun run build:css",
		"check:lint": "biome check",
		"check:format": "biome format --write",
		"check:fix": "bun run check:lint --write",
		"check:fix-unsafe": "bun run check:fix --unsafe",
		"check:deps": "depcruise src",
		"check:deps-graph": "depcruise src --include-only '^src' --output-type dot | dot -Tsvg > dependency-graph.svg",
		"lib:link": "bun link",
		"lib:unlink": "bun unlink",
		"lib:pack": "bun pm pack --filename nodzimo-ui.tgz",
		"deps:install": "bun install",
		"deps:outdated": "bun outdated",
		"deps:update": "bun update --interactive",
		"git:status": "git status",
		"git:pull": "git pull",
		"git:normalize": "git add --renormalize .",
		"git:stash": "git stash",
		"git:stash-pop": "git stash pop",
		"storybook": "storybook dev --port 6006",
		"storybook:test": "vitest --project=storybook",
		"storybook:build": "storybook build",
		"storybook:build-test": "storybook build --test",
		"storybook:upgrade": "bunx storybook@latest upgrade",
		"clean:dist": "bun scripts/clean dist",
		"clean:modules": "bun scripts/clean modules",
		"clean:storybook": "bun scripts/clean storybook",
		"clean:all": "bun scripts/clean dist storybook modules",
		"publish:who": "npm whoami",
		"publish:login": "npm login",
		"publish:fund": "npm fund",
		"publish:fix": "npm pkg fix",
		"publish:bump": "npm version patch",
		"publish:npm": "npm publish"
	},
	"engines": {
		"node": "25.x",
		"bun": "1.3.x"
	},
	"dependencies": {
		"@base-ui/react": "1.4.1",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"tailwind-merge": "3.6.0"
	},
	"peerDependencies": {
		"react": "19.x",
		"react-dom": "19.x"
	},
	"devDependencies": {
		"@babel/core": "7.29.0",
		"@biomejs/biome": "2.4.15",
		"@chromatic-com/storybook": "5.2.1",
		"@microsoft/api-extractor": "7.58.7",
		"@rolldown/plugin-babel": "0.2.3",
		"@storybook/addon-a11y": "10.4.0",
		"@storybook/addon-docs": "10.4.0",
		"@storybook/addon-themes": "10.4.0",
		"@storybook/addon-vitest": "10.4.0",
		"@storybook/react-vite": "10.4.0",
		"@svgr/cli": "8.1.0",
		"@tailwindcss/cli": "4.3.0",
		"@tailwindcss/vite": "4.3.0",
		"@types/babel__core": "7.20.5",
		"@types/node": "25.9.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"@vitest/browser-playwright": "4.1.6",
		"@vitest/coverage-v8": "4.1.6",
		"babel-plugin-react-compiler": "1.0.0",
		"dependency-cruiser": "17.4.0",
		"lucide-react": "1.16.0",
		"playwright": "1.60.0",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"storybook": "10.4.0",
		"storybook-addon-pseudo-states": "10.4.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3",
		"unplugin-dts": "1.0.0",
		"vite": "8.0.13",
		"vitest": "4.1.6"
	}
}
