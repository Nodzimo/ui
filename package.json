{
	"name": "@nodzimo/ui",
	"version": "0.0.15",
	"description": "Sefo Nodzimo UI",
	"keywords": [
		"Sefo",
		"Nodzimo",
		"UI",
		"NUI",
		"SNUI",
		"React",
		"TypeScript",
		"Tailwind",
		"Components",
		"React components",
		"Component library",
		"UI kit",
		"UI system",
		"Design system",
		"Icons",
		"Styles",
		"CSS",
		"RSC-safe",
		"ShadCN",
		"Storybook",
		"RTL",
		"AI-ready",
		"Agent-ready"
	],
	"homepage": "https://ui.Nodzimo.com",
	"bugs": {
		"url": "https://github.com/Nodzimo/ui/issues",
		"email": "Sefo@Nodzimo.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Nodzimo/ui.git"
	},
	"funding": [
		{
			"type": "Individual",
			"url": "https://Nodzimo.com/donate"
		},
		{
			"type": "Boosty",
			"url": "https://boosty.to/Nodzimo"
		},
		{
			"type": "Buy Me a Coffee",
			"url": "https://buymeacoffee.com/Nodzimo"
		},
		{
			"type": "Ko-fi",
			"url": "https://ko-fi.com/Nodzimo"
		}
	],
	"license": "MIT",
	"author": {
		"name": "Sefo Nodzimo",
		"email": "Sefo@Nodzimo.com",
		"url": "https://Nodzimo.com"
	},
	"type": "module",
	"imports": {
		"#client": "./src/client/index.ts",
		"#client/*": "./src/client/*/index.ts",
		"#core": "./src/core/index.ts",
		"#core/*": "./src/core/*/index.ts",
		"#lib": "./src/lib/index.ts",
		"#lib/*": "./src/lib/*/index.ts"
	},
	"exports": {
		".": {
			"types": "./dist/ui.d.ts",
			"import": "./dist/ui.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js"
		},
		"./styles.css": "./dist/styles.css",
		"./theme.css": "./src/theme.css"
	},
	"files": [
		"dist",
		"src/theme.css",
		"docs",
		"AGENTS.md"
	],
	"scripts": {
		"biome:migrate": "biome migrate --write",
		"build": "bun run build:ts && bun run build:js",
		"build:all": "bun run build:icons && bun run build && bun run build:css",
		"build:css": "tailwindcss --input src/styles.css --output dist/styles.css --minify",
		"build:css-watch": "bun run build:css --watch",
		"build:icons": "svgr assets/icons && bun run check:fix-unsafe",
		"build:js": "vite build",
		"build:js-watch": "bun run build:js --watch",
		"build:ts": "tsc --build",
		"build:ts-watch": "bun run build:ts --watch",
		"check:deps": "depcruise src",
		"check:deps-graph": "depcruise src --include-only '^src' --output-type dot | dot -Tsvg > dependency-graph.svg",
		"check:fix": "bun run check:lint --write",
		"check:fix-unsafe": "bun run check:fix --unsafe",
		"check:format": "biome format --write",
		"check:lint": "biome check",
		"clean:all": "bun scripts/clean dist storybook modules",
		"clean:dist": "bun scripts/clean dist",
		"clean:modules": "bun scripts/clean modules",
		"clean:ports": "fkill :5173 :4173 :6006 :6007",
		"clean:storybook": "bun scripts/clean storybook",
		"deps:audit": "bun audit",
		"deps:install": "bun install",
		"deps:outdated": "bun outdated",
		"deps:update": "bun update --interactive",
		"dev": "vite",
		"git:normalize": "git add --renormalize .",
		"git:pull": "git pull",
		"git:push": "git push",
		"git:reset": "git reset",
		"git:stash": "git stash",
		"git:stash-pop": "git stash pop",
		"git:status": "git status",
		"lib:link": "bun link",
		"lib:pack": "bun pm pack --filename ui.tgz",
		"lib:unlink": "bun unlink",
		"preview": "vite preview",
		"project:audit": "bun run build:ts && bun run check:lint && bun run check:deps && bun run deps:outdated",
		"project:verify": "bun run deps:install && bun run project:audit && bun run build:icons && bun run build:js && bun run build:css && bun run lib:pack && bun run storybook:build",
		"publish:dry": "bun publish --dry-run",
		"publish:fix": "bun pm pkg fix",
		"publish:fund": "bunx npm fund",
		"publish:login": "bunx npm login",
		"publish:npmjs": "bun publish",
		"publish:who": "bun pm whoami",
		"release:patch": "bun pm version patch",
		"release:push": "git push --follow-tags",
		"release:version": "bun pm version",
		"storybook": "storybook dev --port 6006",
		"storybook:build": "storybook build",
		"storybook:build-docs": "bun run storybook:build --docs",
		"storybook:build-test": "bun run storybook:build --test",
		"storybook:docs": "bun run storybook --docs",
		"storybook:preview": "bun run storybook:build && bun run storybook:serve",
		"storybook:serve": "bunx http-server storybook-static --port 6007 --coop --cors -c-1",
		"storybook:test": "vitest --project=storybook",
		"storybook:upgrade": "bunx storybook@latest upgrade"
	},
	"dependencies": {
		"@base-ui/react": "1.6.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"tailwind-merge": "3.6.0"
	},
	"devDependencies": {
		"@babel/core": "8.0.1",
		"@biomejs/biome": "2.5.5",
		"@chromatic-com/storybook": "5.2.1",
		"@microsoft/api-extractor": "7.58.12",
		"@rolldown/plugin-babel": "0.2.3",
		"@storybook/addon-a11y": "10.5.3",
		"@storybook/addon-docs": "10.5.3",
		"@storybook/addon-themes": "10.5.3",
		"@storybook/addon-vitest": "10.5.3",
		"@storybook/react-vite": "10.5.3",
		"@svgr/cli": "8.1.0",
		"@tailwindcss/cli": "4.3.3",
		"@tailwindcss/vite": "4.3.3",
		"@types/babel__core": "7.20.5",
		"@types/node": "26.1.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"@vitest/browser-playwright": "4.1.10",
		"@vitest/coverage-v8": "4.1.10",
		"babel-plugin-react-compiler": "1.0.0",
		"dependency-cruiser": "18.1.0",
		"fkill-cli": "9.0.0",
		"playwright": "1.61.1",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"storybook": "10.5.3",
		"storybook-addon-pseudo-states": "10.5.3",
		"storybook-addon-rtl": "3.0.2",
		"storybook-dark-mode": "5.0.0",
		"tailwindcss": "4.3.2",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.3",
		"unplugin-dts": "1.0.3",
		"vite": "8.1.5",
		"vitest": "4.1.10"
	},
	"peerDependencies": {
		"react": "19.x",
		"react-dom": "19.x"
	},
	"engines": {
		"bun": "1.3.x",
		"node": "26.x"
	},
	"publishConfig": {
		"access": "public"
	}
}
